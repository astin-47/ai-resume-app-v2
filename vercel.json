{
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api-config.js",
      "destination": "/api-config.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
